# TripGuard — Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your API keys.

# ── LLM Provider ─────────────────────────────────────────
LLM_PROVIDER=openrouter          # "openrouter" or "ollama"
OLLAMA_MODEL=qwen2.5:72b         # Only needed if LLM_PROVIDER=ollama
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct

# ── Embeddings ───────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=sk-proj-...

# ── Vision (traffic sign detection) ──────────────────────
VISION_MODEL=gpt-4o-mini         # Uses OPENAI_API_KEY above

# ── External APIs ────────────────────────────────────────
TAVILY_API_KEY=tvly-...
TINYFISH_API_KEY=sk-tinyfish-...

# ── Voice (optional) ─────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_TTS_VOICE_ID=

# ── Frontend ─────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000   # Change to Vercel URL for production
